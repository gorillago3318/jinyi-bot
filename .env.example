# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_CHAT_ID=your_telegram_chat_id_here

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── WordPress (optional — for blog cross-posting) ──
WP_URL=https://your-wordpress-site.com
WP_USER=your_wp_username
WP_APP_PASSWORD=your_wp_app_password

# ── Facebook (optional) ───────────────────────
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# ── Instagram (optional — via Facebook Graph API) ──
IG_ACCOUNT_ID=your_instagram_account_id

# ── Timezone ──────────────────────────────────
TZ=Asia/Kuala_Lumpur
